# Glowforge Lifecycle Marketing Engine
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# --- Anthropic Claude API (content generation) ---
# Console: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- HubSpot (email send + contact lists) ---
# HubSpot → Settings → Integrations → Private Apps → Create private app
HUBSPOT_API_KEY=

# --- BigQuery (warehouse audience queries) ---
# Path to a service-account JSON key with read access to the relevant datasets.
# Ask the data team to provision one if you don't have it.
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=
