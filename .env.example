# Glowforge Lifecycle Marketing Engine
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# --- Anthropic Claude API (content generation) ---
# Console: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- HubSpot (email send + contact lists) ---
# HubSpot → Settings → Integrations → Private Apps → Create private app
HUBSPOT_API_KEY=

# --- BigQuery (warehouse audience queries) ---
# Path to a service-account JSON key with read access to the relevant datasets.
# Ask the data team to provision one if you don't have it.
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=

# --- Social: Slack review channel (where scheduled post drafts land) ---
# Channel ID (e.g. C0123ABCD). Mark must be invited to it.
SLACK_REVIEW_CHANNEL=

# --- Social: Meta / Graph API (Facebook Page + Instagram) ---
# Long-lived Page access token. Reporting scopes: pages_read_engagement,
# read_insights. (Publishing later: pages_manage_posts, instagram_basic,
# instagram_content_publish.)
META_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=
META_AD_ACCOUNT_ID=
META_GRAPH_VERSION=v21.0
# SAFETY GATE: publishing to Meta is OFF unless this is exactly "true".
SOCIAL_MARK_ALLOW_PUBLISH=false

# --- Social: content calendar (the posting-cadence Google Sheet) ---
# Reuses GOOGLE_APPLICATION_CREDENTIALS above (share the sheet with that
# service account). Falls back to the public CSV export if the sheet is shared
# "anyone with the link can view".
CONTENT_CALENDAR_SHEET_ID=1eYfKNUu-TPwVd9EpT2rUfrv20S7fWD3N7gr_3g2aKsE
CONTENT_CALENDAR_GID=1006704036
